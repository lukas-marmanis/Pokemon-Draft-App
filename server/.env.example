# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Database ────────────────────────────────────────────────
# Path to SQLite database file (relative to server/ directory)
DATABASE_URL="file:./prisma/draft.db"

# ── Server ──────────────────────────────────────────────────
# Port the backend HTTP/WebSocket server listens on
PORT=3000

# ── CORS ────────────────────────────────────────────────────
# URL of the frontend client (used for CORS allow-list)
# In production, set this to your ngrok/localtunnel URL
CLIENT_URL="http://localhost:5173"

# ── Environment ─────────────────────────────────────────────
NODE_ENV="development"
