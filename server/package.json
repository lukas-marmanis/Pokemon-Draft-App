{
  "name": "pokemon-draft-league-server",
  "version": "1.0.0",
  "description": "Backend server for Pokemon Draft League - Express + Socket.io + Prisma",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "typecheck": "tsc --noEmit",
    "start": "bun src/index.ts",
    "prisma:generate": "node node_modules/.bin/prisma generate",
    "prisma:push": "node node_modules/.bin/prisma db push",
    "prisma:studio": "node node_modules/.bin/prisma studio",
    "db:reset": "rm -f prisma/draft.db && node node_modules/.bin/prisma db push"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.6.1",
    "@prisma/client": "^5.8.0",
    "zod": "^3.22.4",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.3"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.6",
    "prisma": "^5.8.0",
    "vitest": "^1.2.0"
  }
}
